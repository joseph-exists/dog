{
  "schema_version": 1,
  "layout_mode": "panels",
  "runtime_policy": "auto",
  "persona_policy": "first_available",
  "chat_mode": "participant",
  "fixed_user_persona_id": null,
  "page_theme_id": null,
  "cards_theme_id": null,
  "presentation_json": {
    "motion": {
      "panel_enter_ms": 320,
      "block_stagger_ms": 90,
      "easing": "cubic-bezier(0.22, 1, 0.36, 1)"
    },
    "typography": {
      "size": "sm",
      "line_height": "relaxed",
      "heading_font": "Space Grotesk",
      "body_font": "IBM Plex Sans"
    },
    "backgrounds": {
      "page_gradient": "radial-gradient(1200px 560px at 14% 0%, rgba(255, 225, 53, 0.26), rgba(255, 107, 53, 0.20), rgba(255, 107, 157, 0.18), rgba(26, 26, 46, 0.96))",
      "svg_overlay": "grid-wave-v1"
    },
    "effects": {
      "card_glow": {
        "enable": true,
        "css": "0 12px 36px rgba(15, 23, 42, 0.34), 0 0 42px rgba(0, 212, 255, 0.12)"
      }
    },
    "callouts": {
      "header": {
        "style": "neon-frame",
        "text": "Color Ramp Demo",
        "icon": "palette"
      },
      "footer": {
        "style": "glass-pill",
        "text": "Composition-level motion, fonts, overlays, and glow",
        "icon": "sparkles"
      }
    },
    "tokens": {
      "--demo-accent-primary": "#ff6b9d",
      "--demo-accent-secondary": "#00d4ff",
      "--demo-accent-tertiary": "#7fff00",
      "--demo-surface-radius": "18px"
    }
  },
  "metadata_json": {
    "template_id": "docs_color_tests_contract_valid",
    "description": "Contract-valid styling reference payload for demo-builder users. Covers composition, panel, and block presentation_json styling with only currently supported fields.",
    "style_goal": "Show visible color treatment, typography, overlays, glow, callouts, density tokens, and CSS-var pass-through without relying on unsupported keys."
  },
  "panels": [
    {
      "id": "main-chat",
      "kind": "chat",
      "prominence": "primary",
      "order": 1,
      "title": "Color Chat",
      "theme_id": null,
      "presentation_json": {
        "typography": {
          "size": "sm"
        },
        "tokens": {
          "feed_density": "compact"
        },
        "effects": {
          "message_row_highlight": {
            "enable": true,
            "css": "inset 0 0 0 1px rgba(127, 255, 0, 0.42), 0 10px 24px rgba(168, 85, 247, 0.20)"
          }
        },
        "overlays": {
          "panel_header": {
            "css": "linear-gradient(90deg, rgba(255, 225, 53, 0.34), rgba(255, 107, 53, 0.28), rgba(255, 107, 157, 0.26))"
          }
        },
        "callouts": {
          "header": {
            "style": "status-pill",
            "text": "Compact feed + row highlight",
            "icon": "message-square"
          }
        }
      },
      "default_size": 58,
      "min_size": 34,
      "max_size": null,
      "viewport_mode": "panel",
      "options": {
        "mode": "participant",
        "include_internal_messages": false
      }
    },
    {
      "id": "info-panel",
      "kind": "content",
      "prominence": "primary",
      "order": 2,
      "title": "Style Notes",
      "theme_id": null,
      "presentation_json": {
        "motion": {
          "panel_enter_ms": 260
        },
        "overlays": {
          "panel_header": {
            "css": "linear-gradient(120deg, rgba(0, 212, 255, 0.30), rgba(168, 85, 247, 0.24))"
          }
        },
        "callouts": {
          "footer": {
            "style": "framed-note",
            "text": "Panel overlay + panel motion",
            "icon": "info"
          }
        }
      },
      "default_size": 42,
      "min_size": 24,
      "max_size": null,
      "viewport_mode": "panel",
      "options": {
        "content_json": {
          "format": "markdown",
          "value": "## Supported Styling Surface\n\nThis panel uses only supported `presentation_json` keys:\n\n- `overlays.panel_header.css`\n- `motion.panel_enter_ms`\n- `callouts.footer`\n\nUse this file as a copy-paste baseline for demo-builder styling experiments.",
          "metadata": {
            "variant": "card"
          }
        }
      }
    },
    {
      "id": "agent-info",
      "kind": "participantPanel",
      "prominence": "auxiliary",
      "order": 3,
      "title": "Participants",
      "theme_id": null,
      "presentation_json": {
        "overlays": {
          "panel_header": {
            "css": "linear-gradient(135deg, rgba(168, 85, 247, 0.34), rgba(0, 212, 255, 0.22))"
          }
        },
        "callouts": {
          "footer": {
            "style": "glass-pill",
            "text": "Participant shell styling",
            "icon": "users"
          }
        }
      },
      "default_size": 24,
      "min_size": 18,
      "max_size": null,
      "viewport_mode": "panel",
      "options": {
        "showUsers": true,
        "showAgents": true,
        "compact": false,
        "allowQuickAdd": false
      }
    },
    {
      "id": "debug-panel",
      "kind": "debug",
      "prominence": "auxiliary",
      "order": 4,
      "title": "Debug",
      "theme_id": null,
      "presentation_json": {
        "typography": {
          "size": "xs"
        },
        "overlays": {
          "panel_header": {
            "css": "linear-gradient(90deg, rgba(127, 255, 0, 0.25), rgba(0, 212, 255, 0.22))"
          }
        }
      },
      "default_size": 18,
      "min_size": 14,
      "max_size": null,
      "viewport_mode": "panel",
      "options": {}
    }
  ],
  "blocks": [
    {
      "id": "color-hero",
      "type": "context",
      "region": "top",
      "order": 1,
      "title": "Color Hero",
      "visibility": "visible",
      "theme_id": null,
      "presentation_json": {
        "typography": {
          "size": "lg",
          "line_height": "relaxed",
          "heading_font": "Space Grotesk",
          "body_font": "IBM Plex Sans"
        },
        "backgrounds": {
          "card_pattern": {
            "css": "repeating-linear-gradient(135deg, rgba(255, 255, 255, 0.04) 0 12px, rgba(255, 107, 157, 0.08) 12px 24px)"
          }
        },
        "effects": {
          "card_glow": {
            "enable": true,
            "css": "0 0 38px rgba(255, 107, 157, 0.22), 0 0 72px rgba(0, 212, 255, 0.10)"
          }
        },
        "callouts": {
          "header": {
            "style": "runtime-banner",
            "text": "Composition-level background + block glow",
            "icon": "swatch-book"
          }
        }
      },
      "config_json": {},
      "content_json": {
        "format": "markdown",
        "value": "### Color Test Hero\nUse this block to confirm that composition-level gradient, SVG overlay, block glow, and typography are all active together.",
        "metadata": {
          "variant": "card"
        }
      }
    },
    {
      "id": "css-vars-note",
      "type": "content",
      "region": "top",
      "order": 2,
      "title": "CSS Vars Note",
      "visibility": "visible",
      "theme_id": null,
      "presentation_json": {
        "backgrounds": {
          "card_pattern": {
            "css": "linear-gradient(180deg, rgba(255, 225, 53, 0.10), rgba(127, 255, 0, 0.06))"
          }
        },
        "callouts": {
          "footer": {
            "style": "frosted",
            "text": "Custom properties must use --prefixed keys",
            "icon": "variable"
          }
        }
      },
      "config_json": {},
      "content_json": {
        "format": "markdown",
        "value": "#### CSS Variable Contract\nOnly `presentation_json.tokens`, `theme_tokens`, or `css_vars` entries with actual `--prefixed` CSS variable names are passed through.",
        "metadata": {
          "variant": "card"
        }
      }
    },
    {
      "id": "orchestrator-state",
      "type": "orchestratorState",
      "region": "primary",
      "order": 1,
      "title": "Orchestrator State",
      "visibility": "visible",
      "theme_id": null,
      "presentation_json": {
        "tokens": {
          "stack_density": "compact"
        },
        "overlays": {
          "block_header": {
            "css": "linear-gradient(110deg, rgba(168, 85, 247, 0.34), rgba(255, 107, 157, 0.22))"
          }
        },
        "callouts": {
          "header": {
            "style": "neon-frame",
            "text": "Compact stack density",
            "icon": "layers"
          }
        }
      },
      "config_json": {
        "show_agent_list": true,
        "only_active_agents": false
      }
    },
    {
      "id": "tool-capability",
      "type": "toolCapability",
      "region": "primary",
      "order": 2,
      "title": "Tool Capability Matrix",
      "visibility": "visible",
      "theme_id": null,
      "presentation_json": {
        "tokens": {
          "matrix_density": "compact"
        },
        "effects": {
          "card_glow": {
            "enable": true,
            "css": "0 0 28px rgba(127, 255, 0, 0.16)"
          }
        },
        "callouts": {
          "footer": {
            "style": "glass-pill",
            "text": "Compact matrix density + local glow",
            "icon": "grid-2x2"
          }
        }
      },
      "config_json": {
        "only_active_agents": false,
        "show_agent_matrix": true,
        "capability_map": {
          "planner": ["route", "sequence"],
          "coder": ["code", "diff", "execute"],
          "reviewer": ["verify", "approve"]
        }
      }
    },
    {
      "id": "contribution-feed",
      "type": "contributionFeed",
      "region": "auxiliary",
      "order": 1,
      "title": "Contribution Feed",
      "visibility": "visible",
      "theme_id": null,
      "presentation_json": {
        "typography": {
          "size": "sm"
        },
        "tokens": {
          "feed_density": "compact"
        },
        "effects": {
          "message_row_highlight": {
            "css": "inset 0 0 0 1px rgba(0, 212, 255, 0.30), 0 6px 18px rgba(26, 26, 46, 0.24)"
          }
        },
        "callouts": {
          "header": {
            "style": "status-pill",
            "text": "Compact contribution feed",
            "icon": "activity"
          }
        }
      },
      "config_json": {
        "max_items": 8,
        "include_internal": true,
        "show_sender_type": true
      }
    },
    {
      "id": "agent-roster",
      "type": "agentRoster",
      "region": "auxiliary",
      "order": 2,
      "title": "Agent Roster",
      "visibility": "visible",
      "theme_id": null,
      "presentation_json": {
        "backgrounds": {
          "card_pattern": {
            "css": "linear-gradient(160deg, rgba(168, 85, 247, 0.12), rgba(0, 212, 255, 0.08))"
          }
        },
        "callouts": {
          "footer": {
            "style": "framed-note",
            "text": "Card pattern example",
            "icon": "bot"
          }
        }
      },
      "config_json": {}
    },
    {
      "id": "color-footer-guide",
      "type": "content",
      "region": "footer",
      "order": 1,
      "title": "Supported Categories Guide",
      "visibility": "visible",
      "theme_id": null,
      "presentation_json": {
        "overlays": {
          "block_header": {
            "css": "linear-gradient(90deg, rgba(255, 107, 53, 0.30), rgba(255, 225, 53, 0.26))"
          }
        },
        "callouts": {
          "header": {
            "style": "runtime-banner",
            "text": "Supported categories covered here",
            "icon": "check-circle"
          }
        }
      },
      "config_json": {},
      "content_json": {
        "format": "markdown",
        "value": "- motion\n- typography\n- backgrounds.page_gradient\n- backgrounds.svg_overlay\n- backgrounds.card_pattern.css\n- effects.card_glow\n- effects.message_row_highlight\n- overlays.panel_header.css\n- overlays.block_header.css\n- callouts.header/footer\n- tokens.feed_density\n- tokens.stack_density\n- tokens.matrix_density\n- CSS vars via `--prefixed` token keys",
        "metadata": {
          "variant": "card"
        }
      }
    }
  ]
}
