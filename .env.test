# Domain
# This would be set to the production domain with an env var on deployment
# used by Traefik to transmit traffic and aqcuire TLS certificates
DOMAIN=localhost
# To test the local Traefik config
# DOMAIN=localhost.tiangolo.com

# Used by the backend to generate links in emails to the frontend
FRONTEND_HOST=http://localhost:5173
# In staging and production, set this env var to the frontend host, e.g.
# FRONTEND_HOST=https://dashboard.example.com

# Environment: local, staging, production
ENVIRONMENT=local

PROJECT_NAME=dog
STACK_NAME=dogStack

# Backend
BACKEND_CORS_ORIGINS="http://dashboard.localhost, https://dashboard.localhost, http://dashboard.localhost:5173, https://dashboard.localhost:5173, http://localhost,http://localhost:5173,https://localhost,https://localhost:5173,http://localhost.tiangolo.com"
# NEXT TIME YOU ARE FUCKING AROUND WITH CORS
# REMEMBER THAT THE OVERRIDE WILL FORCE THE FRONTEND 
# IT SUCKS WHEN YOU FORGET AND SPEND A DAY AND A HALF FUCKING WITH IT

# you'll need to map these and export them on the kennel server
KENNEL_SECRET=woohoo
KENNEL_EXTERNAL_WS_BASE_URL=ws://localhost:8090
SECRET_KEY=
FIRST_SUPERUSER=
FIRST_SUPERUSER_PASSWORD=
FIRST_SUPERTESTUSER=
FIRST_SUPERTESTUSER_PASSWORD=

# this is for system defaults
OPENAI_API_KEY=

# Emails
SMTP_HOST=
SMTP_USER=what@admin.com
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=example@example.com
SMTP_TLS=True
SMTP_SSL=False
SMTP_PORT=587
EMAIL=change-this
PASSWORD=
# this is what you're gonna hash and then export as HASHED_PASSWORD
USERNAME=
# these are for kennel - leave them alone, they are just test creds.


# Postgres
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=

SENTRY_DSN=

# Configure these with your own Docker registry images
DOCKER_IMAGE_BACKEND=backend
DOCKER_IMAGE_FRONTEND=frontend

REDIS_HOST=localhost
TESSER_REDIS_DB=0
TESSER_REQUEST_CHANNEL=tesser:requests
TESSER_RESPONSE_CHANNEL=tesser:responses
TESSER_WORKER_ID=tesser-worker-1
TESSER_LOG_LEVEL=INFO


# Shadow Gogs provisioning.
# Leave SHADOW_REPO_URL_TEMPLATE empty until SSH auth for the backend/worker is configured.
SHADOW_GOGS_BASE_URL=http://gittin:3000
SHADOW_GOGS_ORG=shadow
# THIS IS DEV ENVIRONMENT TOKEN FOR TESTING.

# you'll have to setup your gogs/gittin instance

SHADOW_GOGS_TOKEN=
SHADOW_REPO_URL_TEMPLATE=
SHADOW_REPO_DEFAULT_BRANCH=main
# THIS IS A DEV ENVIRONMENT TOKEN FOR TESTING
# DEV ENVIRONMENT TOKEN ONLY
USER_REPO_GOGS_TOKEN=
USER_REPO_GOGS_ORG=
USER_REPO_GOGS_BASE_URL=http://gittin:3000
USER_REPO_GIT_USERNAME=
USER_REPO_GIT_PASSWORD=
AGENT_REPO_TOOLS_ENABLED=true
USER_REPO_WORKSPACE_CLONE_BASE_URL=http://gittin:3000

# LOGFIRE_TOKEN=""
